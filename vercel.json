{
  "version": 2,
  "buildCommand": "echo 'Build complete'",
  "outputDirectory": "resume-portfolio-builder",
  "builds": [
    {
      "src": "resume-portfolio-builder/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.9"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "resume-portfolio-builder/app.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production"
  }
}
